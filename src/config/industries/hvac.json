{
  "id": "hvac",
  "displayName": "HVAC",
  "referencePrefix": "HVAC",
  "clientPageDefaults": {
    "headlineTemplate": "Request Service From {businessName}",
    "subheadlineTemplate": "Tell us what's happening with your AC or heating system. {businessName} will review your request and contact you shortly.",
    "submitButtonText": "Submit Service Request"
  },
  "seo": {
    "titleTemplate": "Request a Quote | {businessName}",
    "descriptionTemplate": "Request AC or heating service from {businessName}. Tell us what's going on and get a fast response.",
    "ogImage": "/og/hvac.jpg"
  },
  "serviceCategories": [
    { "id": "emergency-repair", "label": "Emergency Repair" },
    { "id": "routine-maintenance", "label": "Routine Maintenance" },
    { "id": "new-system-quote", "label": "New System Quote" },
    { "id": "ac-not-cooling", "label": "AC Not Cooling" },
    { "id": "heater-not-working", "label": "Heater Not Working" },
    { "id": "strange-noise", "label": "Strange Noise" },
    { "id": "thermostat-issue", "label": "Thermostat Issue" },
    { "id": "other", "label": "Other" }
  ],
  "questions": [
    {
      "id": "issueType",
      "type": "radio",
      "label": "What's going on?",
      "required": true,
      "optionsFrom": "serviceCategories"
    },
    {
      "id": "systemType",
      "type": "dropdown",
      "label": "System type",
      "required": true,
      "options": [
        "Central Air (split system)",
        "Heat Pump",
        "Furnace",
        "Ductless Mini-Split",
        "Packaged Unit",
        "Not sure"
      ]
    },
    { "id": "brand", "type": "text", "label": "Brand (if known)", "required": false, "placeholder": "e.g. Carrier, Trane, Lennox" },
    { "id": "approxAge", "type": "text", "label": "Approximate system age", "required": false, "placeholder": "e.g. 8 years, not sure" },
    {
      "id": "isRunning",
      "type": "dropdown",
      "label": "Is the system currently running?",
      "required": false,
      "options": ["Yes, running but not fixing the issue", "Running intermittently", "No, system is off / won't start"]
    },
    { "id": "symptoms", "type": "textarea", "label": "Symptoms", "required": true, "placeholder": "What is the system doing (or not doing)?" },
    { "id": "startedWhen", "type": "text", "label": "When did the issue start?", "required": false, "placeholder": "e.g. yesterday, 3 days ago" },
    { "id": "unusualNoiseSmell", "type": "text", "label": "Unusual noise or smell?", "required": false, "placeholder": "Describe if applicable" },
    {
      "id": "urgency",
      "type": "radio",
      "label": "Urgency",
      "required": true,
      "options": ["Emergency (today)", "Within 2-3 days", "This week", "Just researching"]
    },
    { "id": "zip", "type": "text", "label": "ZIP code", "required": true, "placeholder": "95814", "validate": "zip" },
    { "id": "name", "type": "text", "label": "Full name", "required": true },
    { "id": "phone", "type": "phone", "label": "Phone", "required": true, "placeholder": "(555) 555-5555" },
    { "id": "email", "type": "email", "label": "Email (optional)", "required": false },
    { "id": "preferredContactTime", "type": "text", "label": "Preferred contact time", "required": false, "placeholder": "e.g. weekday mornings" }
  ],
  "leadScoringRules": [
    { "when": { "field": "urgency", "equals": "Emergency (today)" }, "addPoints": 40 },
    { "when": { "field": "issueType", "equals": "New System Quote" }, "addPoints": 25 },
    { "when": { "field": "isRunning", "equals": "No, system is off / won't start" }, "addPoints": 15 },
    { "when": { "field": "email", "notEmpty": true }, "addPoints": 5 }
  ],
  "faqs": [
    { "q": "How quickly will you respond?", "a": "Most requests are reviewed the same day. Emergency requests are prioritized." },
    { "q": "Does it cost anything to submit a request?", "a": "No, submitting a request is free. Any service pricing is provided directly by our team." },
    { "q": "What happens after I submit?", "a": "Your request goes straight to our team — we'll reach out using the contact info and time you provide." }
  ],
  "feedbackQuestions": [
    { "id": "jobCompleted", "type": "boolean", "label": "Was the job completed?", "required": true },
    { "id": "rating", "type": "rating", "label": "How would you rate the experience?", "required": true },
    {
      "id": "contactSpeed",
      "type": "dropdown",
      "label": "Did we contact you quickly?",
      "required": false,
      "options": ["Same day", "Within 1-2 days", "Longer than 2 days", "Never contacted me"]
    },
    { "id": "comments", "type": "textarea", "label": "Any feedback?", "required": false },
    { "id": "permissionToUseReview", "type": "boolean", "label": "You may use my feedback as a review (optional).", "required": false }
  ],
  "followUpTemplate": "Hi {name}, following up on your recent service request (Ref #{referenceNumber}). A few quick questions:\n1. Was the job completed?\n2. How would you rate the experience (1-5)?\n3. Did we contact you quickly?\n4. Any other feedback?\nYou can also share feedback here: {feedbackLink}",
  "emailTemplates": {
    "leadNotification": {
      "subject": "New quote request — {referenceNumber}",
      "heading": "New quote request"
    },
    "customerConfirmation": {
      "subject": "We received your request — {referenceNumber}",
      "heading": "Request received"
    },
    "feedbackRequest": {
      "subject": "How did your service go?",
      "heading": "Quick follow-up"
    }
  }
}
